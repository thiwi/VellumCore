JWT_ISSUER=bank.local
JWT_AUDIENCE=sentinel-zk
NONCE_WINDOW_SECONDS=300
JWT_MAX_TTL_SECONDS=900
JWT_LEEWAY_SECONDS=30
SUBMIT_RATE_LIMIT_PER_MINUTE=30

DATABASE_URL=postgresql+asyncpg://vellum:vellum@postgres:5432/vellum
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_QUEUE=vellum-queue
REDIS_URL=redis://redis:6379/1

SECURITY_PROFILE=dev
METRICS_REQUIRE_AUTH=false

VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root
VELLUM_JWT_KEY=vellum-jwt
VELLUM_AUDIT_KEY=vellum-audit
VELLUM_BANK_KEY=vellum-bank
VELLUM_DATA_KEY=vellum-data

WORKER_METRICS_HOST=0.0.0.0
WORKER_METRICS_PORT=9108

LOG_LEVEL=INFO
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_FASTAPI_EXCLUDED_URLS=/healthz,/metrics
OTEL_SERVICE_NAMESPACE=vellum-core
ENVIRONMENT=dev
