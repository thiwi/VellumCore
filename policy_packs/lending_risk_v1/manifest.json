{
  "policy_id": "lending_risk_v1",
  "policy_version": "1.0.0",
  "circuit_id": "batch_credit_check",
  "description": "Batch lending risk control that proves all active balances exceed limits.",
  "input_contract": {
    "mode": "balances_limits_or_private_input",
    "required_fields": ["balances", "limits"],
    "max_batch": 250
  },
  "evidence_contract": {
    "type": "json",
    "schema_hint": "Use balances/limits arrays or private_input for pre-normalized circuit payloads."
  },
  "reference_policy": "lending_risk_reference_v1",
  "primitives": [
    "SafeSub",
    "InterestRateValidator",
    "MerkleProof",
    "BalanceGreaterThanLimit",
    "ActiveCountBounds",
    "ZeroPaddingInvariant"
  ],
  "differential_outputs": {
    "all_valid": {
      "signal_index": 0,
      "value_type": "bool"
    },
    "active_count_out": {
      "signal_index": 1,
      "value_type": "int"
    }
  },
  "expected_attestation": {
    "decision_signal_index": 0,
    "pass_signal_value": "1"
  }
}
